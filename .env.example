# LUCID environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API — used for labeling, "See Through It" rewrite, Claude Vision OCR
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API — used for Whisper transcription (preferred) and GPT-4 gold-set cross-labeling
# Optional: if unset, Whisper falls back to local model (slower but free)
OPENAI_API_KEY=sk-...

# Reddit API — used by scripts/scrape_reddit.py
# Create an app at https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=lucid-research/0.1 by u/your_username

# Frontend → backend URL (set in production via Vercel env vars)
NEXT_PUBLIC_API_URL=http://localhost:8000

# HuggingFace Hub — for pushing/pulling trained model artifacts
HF_TOKEN=

# Optional: backend server config
LUCID_MODEL_PATH=models/distilbert
LUCID_LOG_LEVEL=INFO
