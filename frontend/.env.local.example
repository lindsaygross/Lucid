# Copy to .env.local for local dev. Vercel env vars live in the dashboard.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Cinematic intro flag.
# Unset or "true" shows the new persistent-atmosphere + scroll-manifesto
# + polished-analyzer experience. Set to the exact string "false" to render
# the original (pre-cinematic) homepage instead.
NEXT_PUBLIC_CINEMATIC_INTRO=true
